<view class="container">
  <!-- 顶部导航 -->
  <view class="app-header">
    <view class="logo">
      <text class="fa fa-leaf text-primary"></text>
      <text class="title">水稻病虫害识别助手</text>
    </view>
    <view class="version">v1.0.0</view>
  </view>
  
  <!-- 主内容区 -->
  <view class="main-content">
    <!-- 左侧上传和图片展示区 -->
    <view class="left-panel">
      <!-- 上传区域 -->
      <view class="upload-section">
        <view class="upload-card">
          <view class="upload-area">
            <button class="upload-btn" bindtap="chooseImage">
              <text class="fa fa-upload mr-2"></text>
              <text style="font-weight: bold;">选择图片</text>
            </button>
            <button class="{{hasImage ? 'predict-btn' : 'predict-btn-disabled'}}" 
                    bindtap="uploadImage" disabled="{{!hasImage}}">
              <text class="fa fa-search mr-2"></text>
              <text  style="font-weight: bold;color: black;">开始识别</text>
            </button>
          </view>
          
          <view class="upload-hint">
            <text class="fa fa-info-circle"></text>
            <text>支持JPG、PNG格式，建议拍摄清晰的叶片照片</text>
          </view>
        </view>
      </view>
      
      <!-- 图片展示区 -->
      <view class="image-section">
        <view class="image-container">
          <!-- 原始图片 -->
          <view class="image-card fade-in">
            <view class="image-label">
              <text class="fa fa-image"></text>
              <text  style="font-weight: bold;">原始图片</text>
            </view>
            <view class="image-wrapper">
              <image class="show-image" src="{{originalImageUrl}}" mode="aspectFill"></image>
            </view>
          </view>
          
          <!-- 识别结果图片 -->
          <view class="image-card fade-in" wx:if="{{showResult}}">
            <view class="image-label">
              <text class="fa fa-check-circle"></text>
              <text style="font-weight: bold;">识别结果</text>
            </view>
            <view class="image-wrapper">
              <image class="show-image" src="{{resultImageUrl}}" mode="aspectFill"></image>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 右侧结果展示区 -->
    <view class="right-panel">
      <!-- 结果展示区 -->
      <view class="result-section" wx:if="{{showResult}}">
        <view class="result-card slide-up">
          <view class="result-header">
            <view class="result-title">
              <text class="fa fa-bar-chart"></text>
              <text>识别结果详情-------------</text>
              <text>  严重程度：</text>
            </view>
            <view class="severity-badge {{severityClass}}">
              <text>{{severity}}</text>
            </view>
          </view>
          
          <view class="result-details">
            <!-- 病害名称 -->
            <view class="result-item">
              <view class="result-label">
                <text class="fa fa-leaf"></text>
                <text style="font-weight: bold;">病害名称</text>
              </view>
              <text class="result-value">{{diseaseName}}</text>
            </view>
            
            <!-- 置信度 -->
            <view class="result-item">
              <view class="result-label">
                <text class="fa fa-percent"></text>
                <text style="font-weight: bold;">置信度</text>
              </view>
              <view class="confidence-bar">
                <view class="confidence-fill" style="width: {{confidencePercent}}"></view>
              </view>
              <text class="confidence-text">{{confidence}}</text>
            </view>
            
            <!-- 病害描述 -->
            <view class="result-item">
              <view class="result-label">
                <text class="fa fa-book"></text>
                <text style="font-weight: bold;">病害描述</text>
              </view>
              <text class="result-desc">{{description}}</text>
            </view>
            
            <!-- 防治建议 -->
            <view class="result-item">
              <view class="result-label">
                <text class="fa fa-medkit"></text>
                <text style="font-weight: bold;">防治建议</text>
              </view>
              <text class="result-desc">{{treatment}}</text>
            </view>
            
            <!-- 更多信息链接 -->
            <view class="result-item">
              <view class="result-label">
                <text class="fa fa-external-link"></text>
                <text style="font-weight: bold;">更多信息</text>
              </view>
              <navigator url="#" class="more-info-link">
                <text style="font-weight: bold;">查看详细资料</text>
                <text class="fa fa-angle-right ml-2"></text>
              </navigator>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 常见病害指南 -->
      <view class="disease-guide" wx:if="{{!showResult}}">
        <view class="guide-card">
          <view class="guide-header">
            <text class="fa fa-book"></text>
            <text>常见水稻病害指南</text>
          </view>
          <view class="guide-items">
            <!-- 修改：将bindtap事件绑定到text元素上 -->
            <view class="guide-item">
              <image src="../images/bacterial-blight.jpg" mode="aspectFill"></image>
              <text bindtap="showDiseaseDetail" data-id="1">稻瘟病</text>
            </view>
            <view class="guide-item">
              <image src="../images/sheath_blight238.jpg" mode="aspectFill"></image>
              <text bindtap="showDiseaseDetail" data-id="2">纹枯病</text>
            </view>
            <view class="guide-item">
              <image src="../images/bacterial_leaf_blight19.jpg" mode="aspectFill"></image>
              <text bindtap="showDiseaseDetail" data-id="3">白叶枯病</text>
            </view>
            <view class="guide-item">
              <image src="../images/leaf_scald47.jpg" mode="aspectFill"></image>
              <text bindtap="showDiseaseDetail" data-id="4">稻曲病</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 重置按钮 -->
  <view class="action-section" wx:if="{{showResult || errorMessage}}">
    <button class="reset-btn" bindtap="resetImage">
      <text class="fa fa-refresh"></text>
      <text>重新选择图片</text>
    </button>
  </view>
  
  <!-- 页脚 -->
  <view class="app-footer">
    <view class="footer-content">
      <view class="footer-left">
        <text class="footer-text">© 2025 水稻病虫害识别助手</text>
        <text class="footer-text">专业农业科技服务平台</text>
      </view>
      <view class="footer-right">
        <text class="fa fa-envelope-o mr-2"></text>
        <text>contact@example.com</text>
        <text class="fa fa-phone ml-4 mr-2"></text>
        <text>400-123-4567</text>
      </view>
    </view>
  </view>
  
  <!-- 病害详情模态框 -->
  <view class="modal-overlay" wx:if="{{showDiseaseModal}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{selectedDisease.name}}</text>
        <button class="close-btn" bindtap="closeDiseaseModal">
          <text class="fa fa-times"></text>
        </button>
      </view>
      <view class="modal-body">
        <image class="modal-image" src="{{selectedDisease.imageUrl}}" mode="aspectFill"></image>
        <view class="modal-info">
          <view class="info-item">
            <text class="info-label">病害名称：</text>
            <text class="info-value">{{selectedDisease.name}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">发病部位：</text>
            <text class="info-value">{{selectedDisease.affectedPart}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">危害程度：</text>
            <text class="info-value {{selectedDisease.severityClass}}">{{selectedDisease.severity}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">病害描述：</text>
            <text class="info-desc">{{selectedDisease.description}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">防治建议：</text>
            <text class="info-desc">{{selectedDisease.treatment}}</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="confirm-btn" bindtap="closeDiseaseModal">
          <text>我知道了</text>
        </button>
      </view>
    </view>
  </view>
  
  <!-- 加载提示 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="spinner"></view>
      <text class="loading-text">正在识别中，请稍候...</text>
    </view>
  </view>
  
  <!-- 错误提示 -->
  <view class="error-toast" wx:if="{{errorMessage}}">
    <view class="error-content">
      <text class="fa fa-exclamation-circle"></text>
      <text class="error-text">{{errorMessage}}</text>
    </view>
  </view>
</view>