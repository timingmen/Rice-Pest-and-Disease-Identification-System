/* app.wxss */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  background-color: #f5f5f5;
  min-height: 100vh;
  color: #333;
  font-size: 28rpx;
}

button {
  border-radius: 10rpx;
  font-size: 32rpx;
}

button.primary {
  background-color: #1890ff;
  color: white;
}

button.default {
  background-color: #fff;
  border: 1rpx solid #e5e5e5;
  color: #333;
}

.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.text-center {
  text-align: center;
}

.text-danger {
  color: #ff4d4f;
}

.text-warning {
  color: #faad14;
}

.text-neutral {
  color: #1890ff;
}

.text-secondary {
  color: #52c41a;
}

.loading {
  padding: 20rpx;
  text-align: center;
}

.error {
  padding: 20rpx;
  text-align: center;
  color: #ff4d4f;
}    